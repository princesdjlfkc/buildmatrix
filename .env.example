# ---------------------------
# BuildMatrix Backend (.env)
# ---------------------------
PORT=5000

# Session cookie secret
SESSION_SECRET=change-this-secret
SESSION_COOKIE_NAME=buildmatrix.sid

# SQLite database file path
DB_FILE=./buildmatrix.sqlite

# If you run frontend from a different origin (Live Server), add it here (comma-separated)
CLIENT_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Used in password reset email content
CLIENT_URL=http://localhost:5000

# Optional: Email config (for /auth/forgot-password)
# If not set, the backend returns a devToken in the response instead of sending email.
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
